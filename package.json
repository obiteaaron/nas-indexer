{
  "name": "nas-indexer",
  "version": "1.6.0",
  "description": "NAS 文件索引服务 - 离线文件索引、搜索、预览、管理",
  "main": "dist-electron/main.js",
  "bin": "dist/server.js",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "ts-node src/server.ts",
    "dev:watch": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "build:dist": "npm run build && node scripts/create-dist.js",
    "lint": "eslint src/ tests/ --ext .js,.ts",
    "lint:fix": "eslint src/ tests/ --ext .js,.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "electron": "electron .",
    "electron:dev": "npm run build && tsc -p electron/tsconfig.json && electron .",
    "build:electron": "npm run build && tsc -p electron/tsconfig.json",
    "pack": "electron-builder",
    "pack:win": "npm run build:electron && electron-builder --win",
    "pack:mac": "npm run build:electron && electron-builder --mac",
    "pack:linux": "npm run build:electron && electron-builder --linux",
    "pack:all": "npm run build:electron && electron-builder --win --mac --linux"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "profiles/**/*"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "electron": "^42.4.1",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sortablejs": "^1.15.7",
    "sql.js": "^1.14.1",
    "undici": "^8.4.1"
  },
  "keywords": [
    "nas",
    "indexer",
    "markdown"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.8.0",
    "@types/node-cron": "^3.0.11",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "electron-builder": "^25.1.8",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "pkg": "^5.8.1",
    "prettier": "^3.2.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
